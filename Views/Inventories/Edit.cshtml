@model InventoryEditInputModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Edit inventory" : "New inventory";
}

<div class="content-card narrow-card">
    <h1 class="h3 mb-3">@ViewData["Title"]</h1>
    <form asp-action="Save" method="post" class="vstack gap-3">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="Version" type="hidden" />
        <div>
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Category" class="form-label"></label>
                <select asp-for="Category" class="form-select">
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category">@category</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="ImageUrl" class="form-label">Image URL</label>
                <input asp-for="ImageUrl" class="form-control cloud-image-url" placeholder="Cloud-hosted illustration URL" />
                @if (!string.IsNullOrWhiteSpace(Model.CloudinaryCloudName) && !string.IsNullOrWhiteSpace(Model.CloudinaryUploadPreset))
                {
                    <input class="form-control mt-2 cloud-image-upload" type="file" accept="image/*" data-cloud-name="@Model.CloudinaryCloudName" data-upload-preset="@Model.CloudinaryUploadPreset" />
                    <div class="form-text cloud-image-status">Upload sends the image directly to Cloudinary and stores only the returned URL.</div>
                }
            </div>
        </div>
        <div class="position-relative">
            <label asp-for="Tags" class="form-label">Tags</label>
            <input asp-for="Tags" class="form-control" placeholder="equipment, laptop, office" data-tag-lookup-url="@Url.Action("TagLookup")" autocomplete="off" />
            <div id="tag-search-results" class="list-group mt-2"></div>
        </div>
        <div class="form-check">
            <input asp-for="IsPublicWrite" class="form-check-input" />
            <label asp-for="IsPublicWrite" class="form-check-label">Public write access for all authenticated users</label>
        </div>
        <div class="d-flex flex-column flex-sm-row gap-2">
            <button type="submit" class="btn btn-primary flex-fill">Save inventory</button>
            @if (!Model.Id.HasValue)
            {
                <button type="button" class="btn btn-outline-secondary flex-fill" data-fill-inventory-sample>Fill sample</button>
            }
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        initializeTagLookup();
        initializeCloudImageUpload();
        initializeSampleFillers();
    </script>
}
