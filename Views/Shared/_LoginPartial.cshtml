@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject InventoryPilot.Services.UiText T

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link text-body" asp-controller="Profile" asp-action="Index">@T.Get(Context, "My page")</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-body" asp-area="Identity" asp-page="/Account/Manage/Index">@T.Get(Context, "Account")</a>
    </li>
    @if (User.IsInRole("Admin"))
    {
        <li class="nav-item">
            <a class="nav-link text-body" asp-controller="Admin" asp-action="Index">@T.Get(Context, "Admin")</a>
        </li>
    }
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link text-body">@T.Get(Context, "Logout")</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-body" asp-area="Identity" asp-page="/Account/Register">@T.Get(Context, "Register")</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-body" asp-area="Identity" asp-page="/Account/Login">@T.Get(Context, "Login")</a>
    </li>
}
</ul>
