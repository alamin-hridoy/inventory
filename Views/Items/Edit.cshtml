@model ItemEditViewModel
@inject InventoryPilot.Services.UiText T
@{
    ViewData["Title"] = Model.Id.HasValue ? T.Get(Context, "Item details") : T.Get(Context, "New item");
    var canEdit = (bool?)ViewBag.CanEdit ?? false;
}

<div class="content-card narrow-card">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                <h1 class="h3 mb-0">@ViewData["Title"]</h1>
                <span class="mode-badge @(canEdit ? "mode-edit" : "mode-read")">@(canEdit ? T.Get(Context, "Edit mode") : T.Get(Context, "Read-only"))</span>
            </div>
            <div class="text-secondary">@ViewBag.InventoryTitle</div>
        </div>
        @if (Model.Id.HasValue && User.Identity?.IsAuthenticated == true)
        {
            <form asp-action="ToggleLike" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button class="btn btn-outline-primary" type="submit">@T.Get(Context, "Like") (@ViewBag.LikeCount)</button>
            </form>
        }
    </div>
    <form asp-action="Save" method="post" class="vstack gap-3">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="InventoryId" type="hidden" />
        <input asp-for="Version" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3 metadata-strip">
            <div class="col-md-4">
                <label class="form-label">@T.Get(Context, "Created by")</label>
                <input class="form-control" value="@Model.CreatedByName" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label">@T.Get(Context, "Created at")</label>
                <input class="form-control" value="@(Model.CreatedAt?.ToLocalTime().ToString("g") ?? T.Get(Context, "Will be set on save"))" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label">@T.Get(Context, "Updated at")</label>
                <input class="form-control" value="@(Model.UpdatedAt?.ToLocalTime().ToString("g") ?? T.Get(Context, "Not saved yet"))" readonly />
            </div>
        </div>
        <div class="row g-3">
            <div class="col-md-5">
                <label asp-for="CustomId" class="form-label"></label>
                @if (canEdit)
                {
                    <input asp-for="CustomId" class="form-control" />
                }
                else
                {
                    <input asp-for="CustomId" class="form-control" readonly />
                }
            </div>
            <div class="col-md-7">
                <label asp-for="DisplayName" class="form-label"></label>
                @if (canEdit)
                {
                    <input asp-for="DisplayName" class="form-control" />
                }
                else
                {
                    <input asp-for="DisplayName" class="form-control" readonly />
                }
            </div>
        </div>
        @for (var i = 0; i < Model.Fields.Count; i++)
        {
            <input type="hidden" asp-for="Fields[i].FieldDefinitionId" />
            <input type="hidden" asp-for="Fields[i].FieldType" />
            <input type="hidden" asp-for="Fields[i].Title" />
            <input type="hidden" asp-for="Fields[i].Description" />
            <input type="hidden" asp-for="Fields[i].IsRequired" />
            <input type="hidden" asp-for="Fields[i].OptionsJson" />
            <div class="field-block">
                <label class="form-label">@Model.Fields[i].Title</label>
                <div class="small text-secondary mb-2">@Model.Fields[i].Description</div>
                @if (Model.Fields[i].FieldType == "MultiLineText")
                {
                    @if (canEdit)
                    {
                        <textarea asp-for="Fields[i].StringValue" class="form-control" rows="4"></textarea>
                    }
                    else
                    {
                        <textarea asp-for="Fields[i].StringValue" class="form-control" rows="4" readonly></textarea>
                    }
                }
                else if (Model.Fields[i].FieldType == "Number")
                {
                    @if (canEdit)
                    {
                        <input asp-for="Fields[i].NumericValue" class="form-control" type="number" step="0.01" />
                    }
                    else
                    {
                        <input asp-for="Fields[i].NumericValue" class="form-control" type="number" step="0.01" readonly />
                    }
                }
                else if (Model.Fields[i].FieldType == "Boolean")
                {
                    <div class="form-check">
                        @if (canEdit)
                        {
                            <input asp-for="Fields[i].BoolValue" class="form-check-input" />
                        }
                        else
                        {
                            <input asp-for="Fields[i].BoolValue" class="form-check-input" disabled />
                        }
                        <label class="form-check-label">@T.Get(Context, "True / false")</label>
                    </div>
                }
                else if (Model.Fields[i].FieldType == "Select")
                {
                    var options = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.Fields[i].OptionsJson ?? "[]") ?? new List<string>();
                    @if (canEdit)
                    {
                        <select asp-for="Fields[i].StringValue" class="form-select">
                            <option value="">@T.Get(Context, "Select")</option>
                            @foreach (var option in options)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    }
                    else
                    {
                        <select asp-for="Fields[i].StringValue" class="form-select" disabled>
                            <option value="">@T.Get(Context, "Select")</option>
                            @foreach (var option in options)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    }
                }
                else
                {
                    @if (canEdit)
                    {
                        <input asp-for="Fields[i].StringValue" class="form-control" />
                    }
                    else
                    {
                        <input asp-for="Fields[i].StringValue" class="form-control" readonly />
                    }
                    @if (Model.Fields[i].FieldType == "Link" && !string.IsNullOrWhiteSpace(Model.Fields[i].StringValue))
                    {
                        var linkValue = Model.Fields[i].StringValue!;
                        var lowerLink = linkValue.ToLowerInvariant();
                        <div class="document-preview mt-2">
                            @if (lowerLink.EndsWith(".jpg") || lowerLink.EndsWith(".jpeg") || lowerLink.EndsWith(".png") || lowerLink.EndsWith(".webp") || lowerLink.EndsWith(".gif"))
                            {
                                <img src="@linkValue" alt="@Model.Fields[i].Title preview" class="document-preview-image" />
                            }
                            else if (lowerLink.EndsWith(".pdf"))
                            {
                                <iframe src="@linkValue" title="@Model.Fields[i].Title preview" class="document-preview-frame"></iframe>
                            }
                            else
                            {
                                <a href="@linkValue" target="_blank" rel="noreferrer">@T.Get(Context, "Open document")</a>
                            }
                        </div>
                    }
                }
            </div>
        }
        @if (canEdit)
        {
            <button type="submit" class="btn btn-primary">@T.Get(Context, "Save item")</button>
        }
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
